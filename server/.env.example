# 阿里云百炼 (DashScope) API 配置
# 申请地址：https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# LLM 模型选择（OpenAI 兼容）
# 文本解析：qwen-turbo（推荐，快且便宜）| qwen-plus | qwen-max
LLM_MODEL=qwen-turbo

# 画笔绘制模型（空间推理更强，画自定义图形用）
# qwen3.5-omni-plus-2026-03-15（推荐）| qwen-vl-max
BRUSH_MODEL=qwen3.5-omni-plus-2026-03-15

# 服务端口
PORT=3001
